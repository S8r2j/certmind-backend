DATABASE_URL=postgresql://user:password@localhost:5432/certmind

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=2
JWT_REFRESH_EXPIRE_DAYS=7

# AI provider — prefix determines which provider is used:
#   llama-* / mixtral-* → Groq (free tier)
#   gemini-*            → Google Gemini (free tier)
#   claude-*            → Anthropic
AI_MODEL=gemini-2.0-flash
GROQ_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_EXAM_PRICE_ID=price_...

# Upstash Redis (rate limiting + question cache + token blacklist)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=

# SMTP — email verification and password reset
# Leave SMTP_HOST empty to disable sending (links printed to console for local dev)
#
# Gmail:  SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  (use an App Password, not your real password)
# Brevo:  SMTP_HOST=smtp-relay.brevo.com  SMTP_PORT=587  (free 300 emails/day)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@certmind.app
SMTP_FROM_NAME=CertMind

# CORS — set to your frontend domain in production
FRONTEND_URL=http://localhost:3000

# Set to true to skip payment gates during local development
BYPASS_SUBSCRIPTION=true
