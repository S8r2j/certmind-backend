DATABASE_URL=postgresql://user:password@localhost:5432/certmind

# Admin seed — set these to auto-create the first admin on startup
# If the user already exists they are promoted; if already admin nothing changes
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=2
JWT_REFRESH_EXPIRE_DAYS=7

# AI provider — prefix determines which provider is used:
# We have defined 3 models integration that can work.
#   llama-* / mixtral-* → Groq
#   gemini-*            → Google Gemini
#   claude-*            → Anthropic
AI_MODEL=gemini-2.0-flash
GROQ_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_EXAM_PRICE_ID=price_...

# Upstash Redis (rate limiting + question cache + token blacklist)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=

# Email — Brevo HTTP API (https://brevo.com — free 300 emails/day, no SMTP ports needed)
# Sign up → SMTP & API → API Keys → create key → paste below
# Leave empty to disable sending (links printed to console for local dev)
BREVO_API_KEY=
SMTP_FROM_EMAIL=certmindai@gmail.com
SMTP_FROM_NAME=CertMind

# CORS — set to your frontend and backend domains in production
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Set to true to skip payment gates during local development
BYPASS_SUBSCRIPTION=true
